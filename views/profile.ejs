<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-900 font-sans antialiased text-white">

    <div class="min-h-screen flex flex-col items-center p-10">

        <!-- Navigation -->
        <nav class="mb-12 flex gap-6">
            <a class="text-zinc-400 hover:text-blue-500 transition-colors" href="/read">Read Users</a>
            <a class="text-zinc-400 hover:text-blue-500 transition-colors" href="/create">Create User</a>
            <a class="text-red-400 hover:text-red-300" href="/logout">Logout</a>
        </nav>

        <!-- Profile Card -->
        <div class="w-full max-w-md bg-zinc-800/50 p-8 rounded-2xl border border-zinc-800 shadow-xl">

            <div class="flex flex-col items-center gap-4">

                <!-- Avatar -->
                <div class="w-24 h-24 rounded-full bg-blue-600 flex items-center justify-center text-3xl font-bold">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>

                <!-- Name -->
                <h1 class="text-2xl font-bold">
                    <%= user.username %>
                </h1>

                <!-- Email -->
                <p class="text-zinc-400">
                    <%= user.email %>
                </p>

            </div>

            <!-- User Details -->
            <div class="mt-8 flex flex-col gap-4">

                <div class="flex justify-between border-b border-zinc-700 pb-2">
                    <span class="text-zinc-400">User ID</span>
                    <span>
                        <%= user._id %>
                    </span>
                </div>

                <div class="flex justify-between border-b border-zinc-700 pb-2">
                    <span class="text-zinc-400">Account Created</span>
                    <span>
                        <%= user.createdAt %>
                    </span>
                </div>

            </div>

            <!-- Action Buttons -->
            <div class="mt-8 flex gap-3">

                <a href="/edit/<%= user._id %>"
                    class="flex-1 text-center px-4 py-2 bg-blue-600 hover:bg-blue-500 rounded-xl font-semibold transition">
                    Edit Profile
                </a>

                <a href="/delete/<%= user._id %>"
                    class="flex-1 text-center px-4 py-2 bg-red-600 hover:bg-red-500 rounded-xl font-semibold transition">
                    Delete
                </a>

            </div>

        </div>
        <!-- Create Post -->
        <div class="w-full max-w-md mt-10 bg-zinc-800/50 p-6 rounded-2xl border border-zinc-800 shadow-xl">

            <h2 class="text-xl font-semibold mb-4">Create a Post</h2>

            <form action="/post" method="POST" class="flex flex-col gap-3">

                <textarea name="content" placeholder="What's on your mind?"
                    class="w-full bg-zinc-900 border border-zinc-700 rounded-xl p-3 outline-none focus:ring-2 focus:ring-blue-500"
                    rows="3" required></textarea>

                <button class="px-4 py-2 bg-blue-600 hover:bg-blue-500 rounded-xl font-semibold transition">
                    Post
                </button>

            </form>

        </div>
        <!-- User Posts -->
        <div class="w-full max-w-md mt-8">

            <h2 class="text-xl font-semibold mb-4">Your Posts</h2>

            <% if(user.posts.length===0){ %>

                <p class="text-zinc-400">You haven't posted anything yet.</p>

                <% } %>

                    <% user.posts.forEach(post=> { %>
                        <div class="bg-zinc-800 p-4 rounded-xl border border-zinc-700 mb-4">
                            <div class="font-bold text-blue-400 mb-2">
                                <%= user.username %>
                            </div>

                            <p class="text-zinc-200">
                                <%= post.content %>
                            </p>
                            <small class="mt-1"><%= post.likes.length %> likes</small>
                            <div class="btns flex gap-4 mt-5">
                                <a href="/like/<%= post._id %>" class="px-3 py-1 bg-blue-600 hover:bg-blue-500 rounded-xl font-semibold transition">
                                    <%= post.likes.indexOf(user._id)=== -1 ? "Like" : "Unlike" %> 
                                </a>
                                <a href="/edit/<%= post._id %>" class="px-3 py-1 bg-green-600 hover:bg-green-500 rounded-xl font-semibold transition">
                                    Edit
                                </a>
                            </div>

                        </div>

                        <% }) %>

        </div>
    </div>

</body>

</html>